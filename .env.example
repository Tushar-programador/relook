NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/feedspace
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM_EMAIL=no-reply@feedspace.app
SMTP_FROM_NAME=FeedSpace

AWS_REGION=auto
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_BUCKET=feedspace-media
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_PUBLIC_URL=https://cdn.yourdomain.com
SIGNED_URL_EXPIRES_SECONDS=900