# Runtime
NODE_ENV=development
PORT=4000

# Frontend origins allowed to call the API
# CLIENT_URL is the primary origin
CLIENT_URL=http://localhost:5173
# Production: CLIENT_URL=https://relook-web.vercel.app
# Optional extra origins (comma-separated), useful for preview URLs
CLIENT_URLS=

# Database and auth
MONGODB_URI=mongodb+srv://tusharvervebot:<db_password>@cluster0.dem4ltp.mongodb.net/?appName=Cluster0
# Optional fallback for environments that cannot resolve SRV records
# Example from Atlas "Standard connection string" format:
# MONGODB_URI_FALLBACK=mongodb://user:password@ac-xxx-shard-00-00.xxxxx.mongodb.net:27017,ac-xxx-shard-00-01.xxxxx.mongodb.net:27017,ac-xxx-shard-00-02.xxxxx.mongodb.net:27017/feedspace?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
MONGODB_URI_FALLBACK=
JWT_SECRET=456fchgvjhbkjhgfcvhbjnkjhgfchbjbhgcfvhbjsnxasas
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

# Optional SMTP (OTP emails are logged if omitted)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FeedSpace

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
